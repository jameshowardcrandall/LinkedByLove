<section class="how-it-works" id="how-it-works">
    <div class="section-inner reveal">
        <p class="section-label">The Experience</p>
        <h2 class="section-title">How It Works</h2>
        <div class="section-divider"></div>

        <div class="steps">
            <div class="step">
                <div class="step-number">1</div>
                <h3>Choose Your Chain</h3>
                <p>Browse our curated selection of gold-filled and sterling silver chains</p>
            </div>
            <div class="step">
                <div class="step-number">2</div>
                <h3>Get Fitted</h3>
                <p>We measure and custom-fit the chain to your wrist, ankle, or neck</p>
            </div>
            <div class="step">
                <div class="step-number">3</div>
                <h3>Add Charms</h3>
                <p>Personalize your piece with optional charms and dangles</p>
            </div>
            <div class="step">
                <div class="step-number">4</div>
                <h3>Weld &amp; Wear</h3>
                <p>A quick, painless micro-weld seals your jewelry &mdash; it takes just seconds!</p>
            </div>
        </div>
    </div>
</section>

<style>
    .how-it-works {
        background: var(--cream);
    }

    .steps {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 30px;
        margin-top: 20px;
    }

    .step {
        text-align: center;
        padding: 30px 15px;
        position: relative;
    }

    .step:not(:last-child)::after {
        content: '';
        position: absolute;
        top: 50px;
        right: -15px;
        width: 30px;
        height: 1px;
        background: linear-gradient(90deg, var(--gold-light), transparent);
    }

    .step-number {
        font-family: 'Pinyon Script', cursive;
        font-size: 42px;
        color: var(--gold-light);
        margin-bottom: 12px;
        line-height: 1;
    }

    .step h3 {
        font-family: 'Cormorant Garamond', serif;
        font-size: 16px;
        font-weight: 500;
        color: var(--rose);
        margin-bottom: 8px;
    }

    .step p {
        font-size: 12px;
        color: var(--text-light);
        line-height: 1.7;
    }

    @media (max-width: 768px) {
        .steps {
            grid-template-columns: repeat(2, 1fr);
            gap: 20px;
        }

        .step:not(:last-child)::after {
            display: none;
        }
    }

    @media (max-width: 480px) {
        .steps {
            grid-template-columns: 1fr;
        }
    }
</style>
