---

---

<section class="contact" id="contact">
    <div class="section-inner reveal">
        <p class="section-label">Get in Touch</p>
        <h2 class="section-title">Say Hello</h2>
        <div class="section-divider"></div>

        <div class="contact-content">
            <p>
                Ready to get linked? Have questions about booking us for your event?
                We'd love to hear from you!
            </p>

            <div class="contact-methods">
                <div class="contact-method">
                    <div class="label">Email</div>
                    <a href="mailto:hello@linkedbylove.com">hello@linkedbylove.com</a>
                </div>
                <div class="contact-method">
                    <div class="label">Located In</div>
                    <span>Virginia &amp; Maryland</span>
                </div>
            </div>

            <div class="social-links">
                <a href="#" aria-label="Instagram" title="Instagram">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
                        <circle cx="12" cy="12" r="5"></circle>
                        <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"></circle>
                    </svg>
                </a>
                <a href="#" aria-label="Facebook" title="Facebook">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path>
                    </svg>
                </a>
                <a href="#" aria-label="TikTok" title="TikTok">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1 0-5.78 2.84 2.84 0 0 1 .84.13v-3.5a6.37 6.37 0 0 0-.84-.06A6.34 6.34 0 0 0 3.15 15.3 6.34 6.34 0 0 0 9.49 21.64a6.34 6.34 0 0 0 6.34-6.34V8.7a8.16 8.16 0 0 0 4.76 1.52v-3.4a4.85 4.85 0 0 1-1-.13z"/>
                    </svg>
                </a>
            </div>
        </div>
    </div>
</section>

<style>
    .contact {
        background: var(--cream);
    }

    .contact-content {
        text-align: center;
        max-width: 550px;
        margin: 0 auto;
    }

    .contact-content > p {
        font-size: 13px;
        color: var(--text-light);
        line-height: 2;
        margin-bottom: 30px;
    }

    .contact-methods {
        display: flex;
        justify-content: center;
        gap: 40px;
        flex-wrap: wrap;
        margin-bottom: 40px;
    }

    .contact-method {
        text-align: center;
    }

    .label {
        font-size: 10px;
        letter-spacing: 3px;
        text-transform: uppercase;
        color: var(--gold);
        margin-bottom: 6px;
    }

    .contact-method a,
    .contact-method span {
        font-family: 'Cormorant Garamond', serif;
        font-size: 17px;
        color: var(--rose);
        text-decoration: none;
        transition: color 0.3s ease;
    }

    .contact-method a:hover {
        color: var(--rose-dark);
    }

    .social-links {
        display: flex;
        justify-content: center;
        gap: 24px;
        margin-top: 30px;
    }

    .social-links a {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 40px;
        height: 40px;
        border: 1px solid rgba(184, 150, 78, 0.25);
        border-radius: 50%;
        text-decoration: none;
        color: var(--gold);
        font-size: 14px;
        transition: all 0.3s ease;
    }

    .social-links a:hover {
        background: var(--gold);
        color: white;
        border-color: var(--gold);
    }

    @media (max-width: 480px) {
        .contact-methods {
            flex-direction: column;
            gap: 24px;
        }
    }
</style>
